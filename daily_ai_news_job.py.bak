#!/usr/bin/env python3
"""
Daily AI News Job Script
Fetches AI news and sends it via OpenClaw's internal messaging system.
Designed to be run by cron at 8 AM Eastern Time daily.
"""

import sys
import os
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

from get_ai_news import get_all_ai_news, format_news
import json
from datetime import datetime
import subprocess

def send_via_openclaw_internal(message):
    """
    Attempt to send message via OpenClaw's internal systems.
    Since we're running in the OpenClaw environment, we can try to use
    the gateway or session messaging.
    """
    try:
        # Method 1: Try to send via sessions_send if we can determine session
        # For now, we'll output to a file and also try to use the session system
        
        # Save to a known location
        news_file = "/home/node/.openclaw/workspace/daily_ai_news_latest.txt"
        with open(news_file, "w", encoding="utf-8") as f:
            f.write(message)
        
        # Also timestamp it
        timestamp_file = "/home/node/.openclaw/workspace/daily_ai_news_timestamp.txt"
        with open(timestamp_file, "w", encoding="utf-8") as f:
            f.write(f"Last updated: {datetime.now().isoformat()}\n")
            f.write(f"For chat_id: telegram:7681294076\n")
        
        # Try to trigger a notification or update
        # We could try to use the OpenClaw gateway if available
        
        print(f"News saved to {news_file}")
        print(f"Timestamp saved to {timestamp_file}")
        
        # Try to send via sessions_send if we know the session key
        # This is tricky from cron, but we can try to find active sessions
        
        return True
    except Exception as e:
        print(f"Error in sending via internal methods: {e}", file=sys.stderr)
        return False

def main():
    try:
        # Get AI news
        news_items = get_all_ai_news()
        formatted_news = format_news(news_items)
        
        # Add header indicating this is from the automated job
        header = "🤖 **DAILY AUTOMATED AI NEWS** 🤖\n"
        header += f"📅 Delivered: {datetime.now().strftime('%B %d, %Y at %I:%M %p ET')}\n"
        header += "=" * 50 + "\n\n"
        
        full_message = header + formatted_news
        
        # Send via internal methods
        send_via_openclaw_internal(full_message)
        
        # Also print to stdout for cron logging
        print(full_message)
        
    except Exception as e:
        error_msg = f"❌ Error in daily AI news job: {str(e)}\n"
        error_msg += f"Timestamp: {datetime.now().isoformat()}\n"
        print(error_msg, file=sys.stderr)
        
        # Save error for debugging
        with open("/home/node/.openclaw/workspace/ai_news_job_error.txt", "w") as f:
            f.write(error_msg)
        sys.exit(1)

if __name__ == "__main__":
    main()